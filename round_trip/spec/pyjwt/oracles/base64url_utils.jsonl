{"name": "encode_decode_roundtrip", "input": {"data": "hello world"}, "expected": {"roundtrip": true}}
{"name": "encode_no_padding", "input": {"data": "a"}, "expected": {"no_equals_sign": true}}
{"name": "decode_with_missing_padding", "input": {"b64url": "aGVsbG8"}, "expected": {"decoded": "hello"}}
{"name": "to_base64url_uint_zero", "input": {"val": 0}, "expected": {"result": "AA"}}
