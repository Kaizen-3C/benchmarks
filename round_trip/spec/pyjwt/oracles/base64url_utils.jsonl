{"name": "from_base64url_uint_roundtrip", "input": {"val": 65537}, "expected": {"roundtrip": true}}
{"name": "force_bytes_str", "input": {"value": "hello"}, "expected": {"result": "hello", "type": "bytes"}}
{"name": "force_bytes_bytes", "input": {"value": "aGVsbG8="}, "expected": {"type": "bytes"}}
{"name": "force_bytes_invalid_type_raises", "input": {"value": 42}, "expected": {"raises": "TypeError"}}
