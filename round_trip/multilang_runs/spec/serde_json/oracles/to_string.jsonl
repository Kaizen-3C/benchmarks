{"name": "serialize_integer_positive", "input": 42, "expected": "42"}
{"name": "serialize_integer_negative", "input": -7, "expected": "-7"}
{"name": "serialize_float_1_0", "input": 1.0, "expected": "1.0"}
{"name": "serialize_float_3_1", "input": 3.1, "expected": "3.1"}
